# Copy this file to `.env.local` for local development and fill in your key.
# NEVER commit your real key — `.env*` is gitignored.

# Server-side only. Used by the /api/extract and /api/tutor routes.
GEMINI_API_KEY=your-google-gemini-api-key

# Optional: override the Gemini model. Defaults to gemini-3.1-flash-lite (the
# cheapest current multimodal model). Set this to migrate if it's ever retired.
# GEMINI_MODEL=gemini-3.1-flash-lite
